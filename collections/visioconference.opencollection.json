        {
          "info": {
            "name": "Update a meeting",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://api.zoom.us/v2/meetings/:meetingId",
            "params": [
              {
                "name": "meetingId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Update a meeting"
        },
        {
          "info": {
            "name": "Delete a meeting",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.zoom.us/v2/meetings/:meetingId",
            "params": [
              {
                "name": "meetingId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete a meeting"
        }
      ]
    },
