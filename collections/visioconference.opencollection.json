              {
                "name": "userId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Create a meeting"
        },
        {
          "info": {
            "name": "Get a meeting",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.zoom.us/v2/meetings/:meetingId",
            "params": [
              {
                "name": "meetingId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get a meeting"
