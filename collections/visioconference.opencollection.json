          "docs": "Get past meeting's archived files"
        },
        {
          "info": {
            "name": "Delete past meeting's archived files",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.zoom.us/v2/past_meetings/:meetingUUID/archive_files",
            "params": [
              {
                "name": "meetingUUID",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete past meeting's archived files"
        }
      ]
    }
  ],
  "bundled": true
}