          "http": {
            "method": "GET",
            "url": "https://api.zoom.us/v2/meetings/:meetingId/recordings/settings",
            "params": [
              {
                "name": "meetingId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get meeting recording settings"
        },
        {
          "info": {
            "name": "Update recording settings",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://api.zoom.us/v2/meetings/:meetingId/recordings/settings",
