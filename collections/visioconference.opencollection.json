    {
      "info": {
        "name": "Archiving",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List archived files",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.zoom.us/v2/archive_files"
