        },
        {
          "info": {
            "name": "Archived file statistics",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.zoom.us/v2/archive_files/statistics"
          },
          "docs": "Archived file statistics"
        },
        {
          "info": {
            "name": "Get past meeting's archived files",
            "type": "http"
