    "_postman_id": "eace4ff5-3acf-4f47-9b63-6f62a74ce1ad",
    "name": "Zoom Meeting API (Visioconference)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The visioconference (video conferencing) ecosystem profiled in this index\nis anchored by the Zoom REST API. The Zoom API exposes endpoints for\nmanaging meetings, users, recordings, and archived files. All requests\nrequire an OAuth 2.0 access token (server-to-server OAuth or OAuth user\nflow) and are made against https://api.zoom.us/v2.\n\n\nContact Support:\n Name: Zoom Developer Docs",
      "type": "text/plain"
    }
  }
